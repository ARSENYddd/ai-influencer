# ── Image generation ───────────────────────────────────────────────────────────
# Get at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ── Caption generation ─────────────────────────────────────────────────────────
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Instagram ──────────────────────────────────────────────────────────────────
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ── Vector store (Qdrant) ──────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Caption embeddings (OpenAI text-embedding-3-small) ────────────────────────
# Get at: https://platform.openai.com/api-keys
# Used ONLY for embeddings (~$0.00002 per caption), not for generation
OPENAI_API_KEY=your_openai_api_key_here

# ── FastAPI server ─────────────────────────────────────────────────────────────
# Secret token for N8N → FastAPI authentication
# Change this to any random string before deploying
PIPELINE_API_SECRET=changeme
API_PORT=8000
API_RELOAD=false
