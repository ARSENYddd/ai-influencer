# Copy this file to .env and fill in your API keys
# Never commit the actual .env to git

# ── Content generation ─────────────────────────────────────────────────────────

# Leonardo AI — https://app.leonardo.ai/api-access
# Free tier: 150 generations/day
LEONARDO_API_KEY=

# Kling AI — https://platform.klingai.com/
# Paid: from ~$10/month
KLING_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# ~$0.01 per caption request
OPENAI_API_KEY=

# ── Publishing ─────────────────────────────────────────────────────────────────

# Instagram (Meta Graph API v21) — https://developers.facebook.com/
# Requires: Business/Creator account + Meta App + instagram_content_publish permission
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# TikTok — https://developers.tiktok.com/
# Requires: Developer App with Content Posting API (review 2–5 days) + video.publish scope
TIKTOK_ACCESS_TOKEN=

# ── AWS S3 (required for Instagram + TikTok — they need public video URLs) ────

# Create IAM user at https://console.aws.amazon.com/iam
# Required permissions: s3:PutObject, s3:GetObject, s3:HeadBucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Create bucket at https://s3.console.aws.amazon.com/s3
# Enable "Block all public access" OFF + add bucket policy for public GetObject
S3_BUCKET=

# Optional: CloudFront or custom domain URL (leave empty to use default S3 URL)
# Example: https://d1234abcd.cloudfront.net  OR  https://media.yourdomain.com
S3_PUBLIC_BASE_URL=
