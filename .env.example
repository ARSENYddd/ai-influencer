# Copy this file to .env and fill in your API keys
# Never commit the actual .env to git

# Leonardo AI — https://app.leonardo.ai/api-access
LEONARDO_API_KEY=

# Kling AI — https://platform.klingai.com/
KLING_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Instagram (Meta Graph API) — https://developers.facebook.com/
# Requires Business/Creator account + approved app with instagram_content_publish permission
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# TikTok — https://developers.tiktok.com/
# Requires Developer App with Content Posting API access (review takes 2–5 days)
TIKTOK_ACCESS_TOKEN=
